# ──────────────────────────────────────────────
# QA AI Assistant — Environment Configuration


# ── Jira (Atlassian) ─────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=your-email@company.com
JIRA_API_TOKEN=                        # https://id.atlassian.com/manage-profile/security/api-tokens

# ── Zephyr Scale ─────────────────────────────
ZEPHYR_BASE_URL=https://api.zephyrscale.smartbear.com/v2
ZEPHYR_TOKEN=                          # https://support.smartbear.com/zephyr-scale-cloud/docs/rest-api/generating-api-access-tokens.html
ZEPHYR_PROJECT_KEY=                    # e.g. QE (may differ from Jira project key)
